#!/bin/bash

# Detectar display de XWayland
XWAYLAND_DISPLAY=$(ps aux | grep -oP 'Xwayland :\d+' | head -1 | cut -d' ' -f2)

if [ -z "$XWAYLAND_DISPLAY" ]; then
    XWAYLAND_DISPLAY=":1"
fi

export DISPLAY="$XWAYLAND_DISPLAY"
export __NV_PRIME_RENDER_OFFLOAD=1
export __GLX_VENDOR_LIBRARY_NAME=nvidia

# Lanzar Prism Launcher
prime-run /usr/bin/prismlauncher "$@"
