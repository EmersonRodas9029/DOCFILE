#!/bin/bash

# Iniciar el servicio systemd si no está corriendo
if ! systemctl --user is-active --quiet docker-desktop; then
    echo "Iniciando servicio docker-desktop..."
    systemctl --user start docker-desktop
    sleep 2
fi

# Configurar display para Hyprland/XWayland
export DISPLAY=:1

# Lanzar la GUI
echo "Lanzando Docker Desktop GUI..."
exec /opt/docker-desktop/bin/docker-desktop "$@"
